---
const plans = [
  {
    name: "Web Esencial",
    setup: "$250–$400",
    monthly: "$15–$30 / mes",
    highlighted: false,
    cta: "Empezar con Esencial",
    ctaClass: "btn-outline",
    includes: [
      "Landing page (5 secciones)",
      "Diseño responsive",
      "Botón WhatsApp",
      "Formulario básico de contacto",
      "SEO básico",
      "1 revisión por mes",
      "Backup mensual",
    ],
    excludes: [
      "Cambios frecuentes",
      "Nuevas secciones",
      "Gestión de redes sociales",
      "Soporte prioritario",
    ],
    response: "48–72 horas",
  },
  {
    name: "Presencia Profesional",
    setup: "$400–$700",
    monthly: "$40–$80 / mes",
    highlighted: true,
    cta: "Elegir Profesional",
    ctaClass: "btn-yellow",
    includes: [
      "Hasta 5 páginas",
      "Diseño personalizado",
      "Optimización de conversión",
      "SEO + analítica web",
      "3 cambios al mes",
      "Soporte técnico",
      "Backups automáticos",
      "Monitoreo de disponibilidad",
      "Seguridad básica",
    ],
    excludes: [
      "Funcionalidades complejas",
      "Gestión activa de redes",
      "Cambios ilimitados",
    ],
    response: "24–48 horas",
  },
  {
    name: "Presencia Completa",
    setup: "$700–$1,200",
    monthly: "$80–$150 / mes",
    highlighted: false,
    cta: "Elegir Completo",
    ctaClass: "btn-outline",
    includes: [
      "Todo lo del plan Profesional",
      "Redes sociales (Instagram & Facebook)",
      "Optimización de perfiles",
      "Asesoría en contenido",
      "Hasta 4 publicaciones / mes",
      "Soporte prioritario",
      "Revisión mensual de rendimiento",
    ],
    excludes: [
      "Estrategia de marketing paga",
      "Pauta publicitaria",
      "Producción audiovisual profesional",
    ],
    response: "Menos de 24 horas",
  },
];

const WA_URL = "https://wa.me/50661739195?text=Hola%2C%20quiero%20revisar%20mi%20web%20gratis";
---
<section class="pricing" id="planes">
  <div class="container">
    <div class="pricing-header reveal">
      <span class="section-tag">Planes y precios</span>
      <h2 class="section-title">Planes claros, sin letra chica</h2>
      <p class="section-subtitle" style="margin: 0 auto">Elegís el plan que mejor se adapta a tu negocio. Sin contratos anuales forzosos.</p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan, i) => (
        <article class={`plan-card reveal ${plan.highlighted ? 'plan-card--highlighted' : ''}`} style={`transition-delay: ${i * 0.1}s`}>
          {plan.highlighted && <div class="plan-badge">RECOMENDADO</div>}
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-setup">Setup: {plan.setup}</div>
            <div class="plan-monthly">{plan.monthly}</div>
          </div>
          <div class="plan-body">
            <div class="plan-section">
              <div class="plan-section-title">Incluye</div>
              <ul class="plan-list plan-list--yes">
                {plan.includes.map(item => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7l3 3 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="plan-section">
              <div class="plan-section-title">No incluye</div>
              <ul class="plan-list plan-list--no">
                {plan.excludes.map(item => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="plan-response">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 4v3.5l2 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Respuesta: {plan.response}
            </div>
          </div>
          <div class="plan-footer">
            <a href={WA_URL} target="_blank" rel="noopener" class={`btn ${plan.ctaClass} plan-cta`}>{plan.cta}</a>
          </div>
        </article>
      ))}
    </div>

    <!-- Add-ons -->
    <div class="addons reveal">
      <p class="addons-title">Servicios adicionales</p>
      <div class="addons-list">
        <span>Página extra <strong>$50–$100</strong></span>
        <span>Cambio adicional <strong>$10–$25</strong></span>
        <span>Urgencias <strong>+$20</strong></span>
        <span>Rediseño parcial <strong>desde $150</strong></span>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 5rem 0;
    background: var(--color-white);
  }
  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  .plan-card {
    position: relative;
    background: var(--color-gray-soft);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-mid);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: var(--transition), box-shadow var(--transition);
  }
  .plan-card:hover { box-shadow: 0 8px 30px rgba(108,76,241,0.1); transform: translateY(-3px); }
  .plan-card--highlighted {
    border: 2px solid var(--color-purple);
    background: var(--color-white);
    box-shadow: 0 10px 40px rgba(108,76,241,0.15);
  }
  .plan-badge {
    background: var(--color-purple);
    color: white;
    text-align: center;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.4rem;
  }
  .plan-header {
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--color-gray-mid);
  }
  .plan-name {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }
  .plan-setup {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
  }
  .plan-monthly {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-purple);
  }
  .plan-body { padding: 1.5rem 1.75rem; flex: 1; display: flex; flex-direction: column; gap: 1.25rem; }
  .plan-section-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.65rem;
  }
  .plan-list { display: flex; flex-direction: column; gap: 0.55rem; }
  .plan-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .plan-list li svg { flex-shrink: 0; margin-top: 2px; }
  .plan-list--yes li { color: var(--color-navy); }
  .plan-list--yes li svg { color: #16a34a; }
  .plan-list--no li { color: var(--color-text-muted); }
  .plan-list--no li svg { color: #ef4444; }
  .plan-response {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-gray-mid);
  }
  .plan-response svg { color: var(--color-purple); flex-shrink: 0; }
  .plan-footer { padding: 1.25rem 1.75rem 1.75rem; }
  .plan-cta { width: 100%; justify-content: center; }

  /* Addons */
  .addons {
    margin-top: 2.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-gray-soft);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-mid);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }
  .addons-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .addons-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: center;
  }
  .addons-list span { font-size: 0.85rem; color: var(--color-text-muted); }
  .addons-list strong { color: var(--color-navy); }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
