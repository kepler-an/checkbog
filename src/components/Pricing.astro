---
const plans = [
  {
    name: "Web Esencial",
    monthly: "₡15.000",
    highlighted: false,
    cta: "Empezar con Esencial",
    ctaClass: "btn-outline",
    includes: [
      "Landing page (5 secciones)",
      "Diseño responsive",
      "SEO básico y alta en Google",
      "Certificado SSL (Sitio seguro)",
      "1 revisión por mes",
      "Backup mensual",
      "Soporte por correo electrónico",
    ],
    response: "48–72 horas",
  },
  {
    name: "Presencia Profesional",
    monthly: "₡30.000",
    highlighted: true,
    cta: "Elegir Profesional",
    ctaClass: "btn-yellow",
    includes: [
      "Diseño personalizado",
      "SEO + analítica web",
      "Conexión e integración con Facebook e Instagram (no incluye posts mensuales)",
      "Configuración de respuestas automáticas (Facebook Messenger y Instagram y formularios web)",
      "Hasta 2 cuentas de correo corporativo (50 GB c/u)",
      "3 cambios al mes",
      "Actualizaciones de seguridad continuas",
      "Backups automáticos",
      "Monitoreo de disponibilidad",
      "Soporte técnico por WhatsApp",
    ],
    response: "24–48 horas",
  },
  {
    name: "Presencia Completa",
    monthly: "₡50.000",
    highlighted: false,
    cta: "Elegir Completo",
    ctaClass: "btn-outline",
    includes: [
      "Todo lo del plan Profesional",
      "Hasta 5 cuentas de correo corporativo (50 GB c/u)",
      "Optimización de perfiles en redes sociales",
      "Asesoría en contenido digital",
      "4 publicaciones / mes con diseño incluido",
      "Soporte prioritario (WhatsApp + llamadas)",
      "Revisión mensual de rendimiento",
    ],
    response: "Menos de 24 horas",
  },
];

const WA_URL = "https://wa.me/50661739195?text=Hola%2C%20quiero%20revisar%20mi%20web%20gratis";
---
<section class="pricing" id="planes">
  <div class="container">
    <div class="pricing-header reveal">
      <span class="section-tag">Planes y precios</span>
      <h2 class="section-title">Planes claros, sin letra chica</h2>
      <p class="section-subtitle" style="margin: 0 auto">Elegís el plan que mejor se adapta a tu negocio. Sin contratos anuales forzosos.</p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan, i) => (
        <article class={`plan-card reveal ${plan.highlighted ? 'plan-card--highlighted' : ''}`} style={`transition-delay: ${i * 0.1}s`}>
          {plan.highlighted && <div class="plan-badge">RECOMENDADO</div>}
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-monthly">{plan.monthly} <span class="tax"> IVAI/mes</span></div>
          </div>
          <div class="plan-body">
            <div class="plan-section">
              <div class="plan-section-title">Incluye</div>
              <ul class="plan-list plan-list--yes">
                {plan.includes.map(item => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7l3 3 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="plan-response">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 4v3.5l2 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Respuesta: {plan.response}
            </div>
          </div>
          <div class="plan-footer">
            <a href={WA_URL} target="_blank" rel="noopener" class={`btn ${plan.ctaClass} plan-cta`}>{plan.cta}</a>
          </div>
        </article>
      ))}
    </div>

    <!-- Add-ons -->
    <div class="addons reveal">
      <p class="addons-title">Servicios adicionales</p>

      <!-- Implementación destacada -->
      <div class="addon-impl">
        <div class="addon-impl-left">
          <span class="addon-impl-badge">Pago único</span>
          <p class="addon-impl-name">Implementación inicial</p>
          <p class="addon-impl-desc">Creación, configuración e instalación inicial de tu sitio — se cobra una sola vez al comenzar.</p>
          <p class="addon-impl-domain">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.6"/><path d="M10 1.5C10 1.5 7 5.5 7 10s3 8.5 3 8.5M10 1.5C10 1.5 13 5.5 13 10s-3 8.5-3 8.5M1.5 10h17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            ¿Sin dominio? Lo gestionamos — <strong>primer año gratis</strong>, luego renovación anual con costo.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 5rem 0;
    background: var(--color-white);
  }
  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  .plan-card {
    position: relative;
    background: var(--color-gray-soft);
    border-radius: var(--radius-md);
    border: 1px solid rgba(108, 76, 241, 0.25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow:
      0 0 18px rgba(108, 76, 241, 0.14),
      0 0 40px rgba(108, 76, 241, 0.07);
    transition: var(--transition), box-shadow var(--transition);
  }
  .plan-card:hover {
    box-shadow:
      0 0 26px rgba(108, 76, 241, 0.24),
      0 0 55px rgba(108, 76, 241, 0.12);
    transform: translateY(-3px);
  }
  .plan-card--highlighted {
    border: 2px solid rgba(108, 76, 241, 0.55);
    background: var(--color-white);
    box-shadow:
      0 0 30px rgba(108, 76, 241, 0.38),
      0 0 65px rgba(108, 76, 241, 0.20),
      0 0 100px rgba(108, 76, 241, 0.10);
  }
  .plan-card--highlighted:hover {
    box-shadow:
      0 0 40px rgba(108, 76, 241, 0.50),
      0 0 80px rgba(108, 76, 241, 0.26),
      0 0 120px rgba(108, 76, 241, 0.13);
  }
  .plan-badge {
    background: var(--color-purple);
    color: white;
    text-align: center;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 0.4rem;
  }
  .plan-header {
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--color-gray-mid);
  }
  .plan-name {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }
  .plan-monthly {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-purple);
  }
  .tax {
    font-size: 0.7em;
    font-weight: 500;
    color: var(--color-text-muted);
    vertical-align: middle;
  }
  .plan-body { padding: 1.5rem 1.75rem; flex: 1; display: flex; flex-direction: column; gap: 1.25rem; }
  .plan-section-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.65rem;
  }
  .plan-list { display: flex; flex-direction: column; gap: 0.55rem; }
  .plan-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .plan-list li svg { flex-shrink: 0; margin-top: 2px; }
  .plan-list--yes li { color: var(--color-navy); }
  .plan-list--yes li svg { color: #16a34a; }
  .plan-response {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-gray-mid);
  }
  .plan-response svg { color: var(--color-purple); flex-shrink: 0; }
  .plan-footer { padding: 1.25rem 1.75rem 1.75rem; }
  .plan-cta { width: 100%; justify-content: center; }

  /* ── Addons wrapper ── */
  .addons {
    margin-top: 2.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-gray-soft);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-mid);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  .addons-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ── Implementación inicial ── */
  .addon-impl {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-purple-light);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.4rem;
    width: 100%;
  }
  .addon-impl-left { display: flex; flex-direction: column; gap: 0.3rem; }
  .addon-impl-badge {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-purple);
    background: rgba(108,76,241,0.08);
    border: 1px solid rgba(108,76,241,0.2);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    width: fit-content;
  }
  .addon-impl-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
  }
  .addon-impl-desc {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.5;
  }
  .addon-impl-domain {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #4b5563;
    background: rgba(108,76,241,0.06);
    border: 1px dashed rgba(108,76,241,0.25);
    border-radius: 6px;
    padding: 0.45rem 0.65rem;
    line-height: 1.45;
    margin-top: 0.25rem;
  }
  .addon-impl-domain svg { flex-shrink: 0; margin-top: 2px; color: var(--color-purple); }
  .addon-impl-domain strong { color: var(--color-navy); }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    /* Wrapper */
    .addons { padding: 1rem; gap: 0.85rem; }

    /* Implementación inicial */
    .addon-impl {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
      padding: 1rem;
    }
    .addon-impl-left { width: 100%; }
    .addon-impl-domain { font-size: 0.85rem; }
  }
</style>
