---
const without = [
  "Web desactualizada o rota",
  "Sin saber si funciona o no",
  "Redes que no reflejan tu marca",
  "Sin respaldo ante un ataque",
  "Proveedores distintos sin coordinación",
  "Perdés oportunidades sin darte cuenta",
];
const with_ = [
  "Web moderna, rápida y en línea",
  "Monitoreo y alertas en tiempo real",
  "Imagen consistente en todos los canales",
  "Seguridad básica y backups automáticos",
  "Un solo equipo que lo maneja todo",
  "Presencia que trabaja para vos 24/7",
];
---
<section class="diff" id="por-que">
  <div class="diff-glow"></div>
  <div class="container">

    <div class="diff-header reveal">
      <span class="section-tag">Por qué Checkbog</span>
      <h2 class="section-title">La mayoría tiene piezas sueltas.<br/>Checkbog las conecta.</h2>
    </div>

    <div class="diff-panel reveal">

      <!-- Sin Checkbog -->
      <div class="diff-col diff-col--bad">
        <div class="diff-col-header">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="9" stroke="currentColor" stroke-width="2"/>
            <path d="M7 7l8 8M15 7l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Sin Checkbog
        </div>
        <ul class="diff-list">
          {without.map(item => (
            <li>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- VS divider -->
      <div class="diff-divider" aria-hidden="true">
        <span class="diff-vs">VS</span>
      </div>

      <!-- Con Checkbog -->
      <div class="diff-col diff-col--good">
        <div class="diff-col-header">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="9" stroke="currentColor" stroke-width="2"/>
            <path d="M6 11l4 4 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Con Checkbog
        </div>
        <ul class="diff-list">
          {with_.map(item => (
            <li>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div><!-- /.diff-panel -->

    <!-- CTA -->
    <div class="diff-cta reveal">
      <a href="#contacto" class="btn btn-yellow">Empezar con una revisión gratis</a>
      <p class="diff-trust">Sin contratos largos &middot; Cancelás cuando querás</p>
    </div>

  </div>
</section>

<style>
  .diff {
    position: relative;
    padding: 5rem 0;
    background: var(--color-navy);
    overflow: hidden;
  }
  .diff-glow {
    position: absolute;
    right: -120px;
    top: 50%;
    transform: translateY(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(108,76,241,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .diff-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .diff-header .section-tag  { color: var(--color-purple-light); }
  .diff-header .section-title { color: var(--color-white); }

  /* ── Panel ── */
  .diff-panel {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    max-width: 900px;
    margin: 0 auto 3rem;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(108,76,241,0.22);
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }

  /* ── Columns ── */
  .diff-col { padding: 2.25rem 2rem; }

  .diff-col--bad  { background: rgba(239,68,68,0.05); }
  .diff-col--good {
    background: rgba(108,76,241,0.12);
    box-shadow: inset 0 0 80px rgba(108,76,241,0.07);
  }

  .diff-col-header {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid;
  }
  .diff-col--bad  .diff-col-header { color: rgba(239,68,68,0.85); border-color: rgba(239,68,68,0.2); }
  .diff-col--good .diff-col-header { color: var(--color-purple-light); border-color: rgba(108,76,241,0.25); }

  .diff-list { display: flex; flex-direction: column; gap: 0.9rem; }
  .diff-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.93rem;
    line-height: 1.5;
  }
  .diff-list li svg { flex-shrink: 0; margin-top: 3px; }

  .diff-col--bad  .diff-list li     { color: rgba(255,255,255,0.6); }
  .diff-col--bad  .diff-list li svg { color: rgba(239,68,68,0.8); }
  .diff-col--good .diff-list li     { color: rgba(255,255,255,0.9); }
  .diff-col--good .diff-list li svg { color: #a78bfa; }

  /* ── VS divider ── */
  .diff-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080f1e;
    border-left:  1px solid rgba(108,76,241,0.15);
    border-right: 1px solid rgba(108,76,241,0.15);
  }
  .diff-divider::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 1px;
    background: rgba(108,76,241,0.2);
    transform: translateX(-50%);
  }
  .diff-vs {
    position: relative;
    z-index: 1;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #080f1e;
    border: 1.5px solid rgba(108,76,241,0.5);
    color: var(--color-purple-light);
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── CTA ── */
  .diff-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
  }
  .diff-trust {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
  }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .diff-panel { grid-template-columns: 1fr; }
    .diff-divider {
      border-left: none;
      border-right: none;
      border-top: 1px solid rgba(108,76,241,0.15);
      border-bottom: 1px solid rgba(108,76,241,0.15);
      padding: 0.9rem;
    }
    .diff-divider::before { display: none; }
  }
</style>
