---
const WA_URL = "https://wa.me/50661739195?text=Hola%2C%20quiero%20revisar%20mi%20web%20gratis";
---
<section class="hero">
  <div class="hero-glow"></div>
  <div class="container hero-inner">
    <div class="hero-text reveal">
      <p class="hero-eyebrow">Presencia digital profesional</p>
      <h1 class="hero-headline">
        ¿Pierdes clientes por una web desactualizada?
      </h1>
      <p class="hero-sub">
        Checkbog optimiza, mantiene y conecta tu presencia digital — para que no pierdas más oportunidades.
      </p>
      <div class="hero-actions">
        <a href="#contacto" class="btn btn-yellow">Revisar mi web gratis</a>
        <a href={WA_URL} target="_blank" rel="noopener" class="btn btn-ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribinos por WhatsApp
        </a>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="problems-panel">
        <p class="problems-panel-label">¿Te suena familiar?</p>
        <div class="problems-panel-grid">
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="2"/><path d="M16 9v8M16 22v1" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
            </div>
            <p class="pp-title">Sitio web desactualizado o lento</p>
            <p class="pp-desc">Tus clientes lo visitan una vez y no vuelven.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"><path d="M6 26V16a10 10 0 0120 0v10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M6 26h20M12 26v-4a4 4 0 018 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <p class="pp-title">No generás leads ni contactos</p>
            <p class="pp-desc">Tu web existe pero no convierte a nadie.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="5" y="5" width="10" height="10" rx="2" stroke="currentColor" stroke-width="2"/><rect x="17" y="5" width="10" height="10" rx="2" stroke="currentColor" stroke-width="2"/><rect x="5" y="17" width="10" height="10" rx="2" stroke="currentColor" stroke-width="2"/><rect x="17" y="17" width="10" height="10" rx="2" stroke="currentColor" stroke-width="2" stroke-dasharray="3 2"/></svg>
            </div>
            <p class="pp-title">Redes sociales inconsistentes</p>
            <p class="pp-desc">Tu marca no se ve igual en todos lados.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"><path d="M16 4l10 4v8c0 6-4.4 10.4-10 12C10.4 26.4 6 22 6 16V8l10-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M11 16l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <p class="pp-title">Seguridad descuidada</p>
            <p class="pp-desc">Un hackeo o caída puede costarte clientes y reputación.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px 0 80px;
  }
  .hero-glow {
    position: absolute;
    top: -160px;
    right: -160px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(108,76,241,0.22) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1rem;
  }
  .hero-headline {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-visual { display: flex; justify-content: center; align-items: center; }

  .problems-panel {
    width: 100%;
    max-width: 480px;
    background: rgba(15, 30, 56, 0.7);
    border: 1px solid rgba(108,76,241,0.35);
    border-radius: 16px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 20px 50px rgba(108,76,241,0.2);
  }
  .problems-panel-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1.25rem;
  }
  .problems-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .pp-card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    padding: 1.1rem;
    background: transparent;
  }
  /* Worm: rotating conic-gradient arc */
  .pp-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 320deg,
      rgba(108,76,241,0.5) 340deg,
      #a78bfa 350deg,
      rgba(139,111,245,0.8) 356deg,
      transparent 360deg
    );
    animation: worm-spin 4s linear infinite;
    z-index: 0;
  }
  /* Interior fill — covers center so only the border arc shows */
  .pp-card::after {
    content: '';
    position: absolute;
    inset: 1.5px;
    background: #0c1b32;
    border-radius: 9px;
    z-index: 1;
  }
  /* Stagger starting position per card */
  .pp-card:nth-child(1)::before { animation-delay: 0s; }
  .pp-card:nth-child(2)::before { animation-delay: -1s; }
  .pp-card:nth-child(3)::before { animation-delay: -2s; }
  .pp-card:nth-child(4)::before { animation-delay: -3s; }

  .pp-card:hover::before {
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 300deg,
      rgba(108,76,241,0.7) 330deg,
      #c4b5fd 348deg,
      rgba(139,111,245,1) 356deg,
      transparent 360deg
    );
    animation-duration: 2.5s;
  }
  .pp-icon {
    position: relative;
    z-index: 2;
    color: var(--color-purple-light);
    margin-bottom: 0.65rem;
    line-height: 0;
  }
  .pp-title {
    position: relative;
    z-index: 2;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .pp-desc {
    position: relative;
    z-index: 2;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  @keyframes worm-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-visual { order: -1; }
    .hero-mockup { max-width: 380px; }
  }
  @media (max-width: 480px) {
    .hero { padding: 100px 0 60px; }
    .hero-actions { flex-direction: column; align-items: center; }
    .btn { width: 100%; justify-content: center; }
  }
</style>
