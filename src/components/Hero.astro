          </svg>
          Escribinos por WhatsApp
        </a>
      </div>
    </div>

    <!-- Abstract browser/dashboard SVG mockup -->
    <div class="hero-visual reveal">
      <svg viewBox="0 0 460 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-mockup" aria-hidden="true">
