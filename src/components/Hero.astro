<section class="hero">
  <div class="hero-glow"></div>
  <div class="aurora" aria-hidden="true">
    <div class="aurora-blob aurora-blob--1"></div>
    <div class="aurora-blob aurora-blob--2"></div>
    <div class="aurora-blob aurora-blob--3"></div>
  </div>
  <canvas id="hero-3d" aria-hidden="true"></canvas>
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-eyebrow">Presencia digital profesional</p>
      <h1 class="hero-headline">¿Web desactualizada o necesitas una?</h1>
      <p class="hero-sub">
        Checkbog optimiza, mantiene y conecta tu presencia digital — para que no
        pierdas más oportunidades.
      </p>
      <div class="hero-actions">
        <a href="#contacto" class="btn btn-yellow">Contáctanos</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="problems-panel">
        <p class="problems-panel-label">¿Te suena familiar?</p>
        <div class="problems-panel-grid">
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><circle
                  cx="16"
                  cy="16"
                  r="13"
                  stroke="currentColor"
                  stroke-width="2"></circle><path
                  d="M16 9v8M16 22v1"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"></path></svg
              >
            </div>
            <p class="pp-title">Sitio web desactualizado o lento</p>
            <p class="pp-desc">Tus clientes lo visitan una vez y no vuelven.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><path
                  d="M6 26V16a10 10 0 0120 0v10"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path><path
                  d="M6 26h20M12 26v-4a4 4 0 018 0v4"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path></svg
              >
            </div>
            <p class="pp-title">No generás leads ni contactos</p>
            <p class="pp-desc">Tu web existe pero no convierte a nadie.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><rect
                  x="5"
                  y="5"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="17"
                  y="5"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="5"
                  y="17"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="17"
                  y="17"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-dasharray="3 2"></rect></svg
              >
            </div>
            <p class="pp-title">Redes sociales inconsistentes</p>
            <p class="pp-desc">Tu marca no se ve igual en todos lados.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><path
                  d="M16 4l10 4v8c0 6-4.4 10.4-10 12C10.4 26.4 6 22 6 16V8l10-4z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linejoin="round"></path><path
                  d="M11 16l3 3 7-7"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </div>
            <p class="pp-title">Seguridad descuidada</p>
            <p class="pp-desc">
              Un hackeo o caída puede costarte clientes y reputación.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px 0 80px;
  }

  /* ── Three.js canvas ── */
  #hero-3d {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* ── Aurora blobs ── */
  .aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
    opacity: 0.55;
  }
  .aurora-blob--1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(108,76,241,0.5) 0%, transparent 70%);
    top: -120px;
    right: -80px;
    animation: aurora1 18s ease-in-out infinite alternate;
  }
  .aurora-blob--2 {
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(139,111,245,0.4) 0%, transparent 70%);
    bottom: -60px;
    left: -100px;
    animation: aurora2 14s ease-in-out infinite alternate;
  }
  .aurora-blob--3 {
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(79,70,229,0.45) 0%, transparent 70%);
    top: 40%;
    left: 35%;
    animation: aurora3 10s ease-in-out infinite alternate;
  }
  @keyframes aurora1 {
    0%   { transform: translate(0, 0) scale(1); }
    30%  { transform: translate(-80px, 60px) scale(1.1); }
    60%  { transform: translate(40px, 100px) scale(0.95); }
    100% { transform: translate(-40px, 30px) scale(1.05); }
  }
  @keyframes aurora2 {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(100px, -70px) scale(1.15); }
    70%  { transform: translate(60px, -120px) scale(0.9); }
    100% { transform: translate(30px, -50px) scale(1.08); }
  }
  @keyframes aurora3 {
    0%   { transform: translate(0, 0) scale(1) rotate(0deg); }
    50%  { transform: translate(-60px, -80px) scale(1.2) rotate(20deg); }
    100% { transform: translate(80px, 40px) scale(0.85) rotate(-15deg); }
  }

  .hero-glow {
    position: absolute;
    top: -160px;
    right: -160px;
    width: 700px;
    height: 700px;
    background: radial-gradient(
      circle,
      rgba(108, 76, 241, 0.22) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* ── Entry animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 1000;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }
  .hero-headline {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    background: linear-gradient(105deg, #ffffff 30%, #d8d0fb 48%, #b8a9f7 55%, #ffffff 72%);
    background-size: 260% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.32s forwards, shimmer 8s ease-in-out 1.25s infinite;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
    max-width: 480px;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.66s forwards;
  }
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    animation: fadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.38s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-headline,
    .hero-sub,
    .hero-actions,
    .hero-visual {
      opacity: 1;
      animation: none;
    }
    .hero-headline {
      background: none;
      -webkit-text-fill-color: var(--color-white);
      color: var(--color-white);
    }
    #hero-3d { display: none; }
  }

  .problems-panel {
    width: 100%;
    max-width: 560px;
    background: rgba(15, 30, 56, 0.7);
    border: 1px solid rgba(108, 76, 241, 0.35);
    border-radius: 16px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 20px 50px rgba(108, 76, 241, 0.2);
  }
  .problems-panel-label {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1.25rem;
    text-align: center;
  }
  .problems-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .pp-card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    padding: 1.1rem;
    background: transparent;
  }
  /* Worm: rotating conic-gradient arc */
  .pp-card::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 320deg,
      rgba(108, 76, 241, 0.5) 340deg,
      #a78bfa 350deg,
      rgba(139, 111, 245, 0.8) 356deg,
      transparent 360deg
    );
    animation: worm-spin 4s linear infinite;
    z-index: 0;
  }
  /* Interior fill — covers center so only the border arc shows */
  .pp-card::after {
    content: "";
    position: absolute;
    inset: 1.5px;
    background: #0c1b32;
    border-radius: 9px;
    z-index: 1;
  }
  .pp-card:nth-child(1)::before { animation-delay: 0s; }
  .pp-card:nth-child(2)::before { animation-delay: -1s; }
  .pp-card:nth-child(3)::before { animation-delay: -2s; }
  .pp-card:nth-child(4)::before { animation-delay: -3s; }

  .pp-card:hover::before {
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 300deg,
      rgba(108, 76, 241, 0.7) 330deg,
      #c4b5fd 348deg,
      rgba(139, 111, 245, 1) 356deg,
      transparent 360deg
    );
    animation-duration: 2.5s;
  }
  .pp-icon {
    position: relative;
    z-index: 2;
    color: var(--color-purple-light);
    margin-bottom: 0.65rem;
    line-height: 0;
  }
  .pp-title {
    position: relative;
    z-index: 2;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .pp-desc {
    position: relative;
    z-index: 2;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  @keyframes worm-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-sub {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-visual {
      order: -1;
    }
    .hero-mockup {
      max-width: 380px;
    }
  }
  @media (max-width: 480px) {
    .hero {
      padding: 100px 0 60px;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  // El 3D del Hero es decorativo. Cargamos three.js de forma diferida (en idle) y
  // sólo si hay canvas y el usuario no pidió reducir el movimiento. Así three.js
  // queda en un chunk aparte, fuera de la ruta crítica de carga.
  const canvas = document.getElementById('hero-3d') as HTMLCanvasElement | null;

  if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const start = () =>
      import('../scripts/hero3d').then(({ initHero3D }) => initHero3D(canvas));
    if ('requestIdleCallback' in window) {
      requestIdleCallback(start, { timeout: 2000 });
    } else {
      setTimeout(start, 300);
    }
  }
</script>
