<section class="hero">
  <div class="hero-glow"></div>
  <div class="container hero-inner">
    <div class="hero-text reveal">
      <p class="hero-eyebrow">Presencia digital profesional</p>
      <h1 class="hero-headline">¿Web desactualizada o necesitas una?</h1>
      <p class="hero-sub">
        Checkbog optimiza, mantiene y conecta tu presencia digital — para que no
        pierdas más oportunidades.
      </p>
      <div class="hero-actions">
        <a href="#contacto" class="btn btn-yellow">Contáctanos</a>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="problems-panel">
        <p class="problems-panel-label">¿Te suena familiar?</p>
        <div class="problems-panel-grid">
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><circle
                  cx="16"
                  cy="16"
                  r="13"
                  stroke="currentColor"
                  stroke-width="2"></circle><path
                  d="M16 9v8M16 22v1"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"></path></svg
              >
            </div>
            <p class="pp-title">Sitio web desactualizado o lento</p>
            <p class="pp-desc">Tus clientes lo visitan una vez y no vuelven.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><path
                  d="M6 26V16a10 10 0 0120 0v10"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path><path
                  d="M6 26h20M12 26v-4a4 4 0 018 0v4"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path></svg
              >
            </div>
            <p class="pp-title">No generás leads ni contactos</p>
            <p class="pp-desc">Tu web existe pero no convierte a nadie.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><rect
                  x="5"
                  y="5"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="17"
                  y="5"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="5"
                  y="17"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect><rect
                  x="17"
                  y="17"
                  width="10"
                  height="10"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-dasharray="3 2"></rect></svg
              >
            </div>
            <p class="pp-title">Redes sociales inconsistentes</p>
            <p class="pp-desc">Tu marca no se ve igual en todos lados.</p>
          </div>
          <div class="pp-card">
            <div class="pp-icon">
              <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                ><path
                  d="M16 4l10 4v8c0 6-4.4 10.4-10 12C10.4 26.4 6 22 6 16V8l10-4z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linejoin="round"></path><path
                  d="M11 16l3 3 7-7"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </div>
            <p class="pp-title">Seguridad descuidada</p>
            <p class="pp-desc">
              Un hackeo o caída puede costarte clientes y reputación.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px 0 80px;
  }
  .hero-glow {
    position: absolute;
    top: -160px;
    right: -160px;
    width: 700px;
    height: 700px;
    background: radial-gradient(
      circle,
      rgba(108, 76, 241, 0.22) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 1000;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1rem;
  }
  .hero-headline {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .problems-panel {
    width: 100%;
    max-width: 560px;
    background: rgba(15, 30, 56, 0.7);
    border: 1px solid rgba(108, 76, 241, 0.35);
    border-radius: 16px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 20px 50px rgba(108, 76, 241, 0.2);
  }
  .problems-panel-label {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1.25rem;
    text-align: center;
  }
  .problems-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .pp-card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    padding: 1.1rem;
    background: transparent;
  }
  /* Worm: rotating conic-gradient arc */
  .pp-card::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 12px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 320deg,
      rgba(108, 76, 241, 0.5) 340deg,
      #a78bfa 350deg,
      rgba(139, 111, 245, 0.8) 356deg,
      transparent 360deg
    );
    animation: worm-spin 4s linear infinite;
    z-index: 0;
  }
  /* Interior fill — covers center so only the border arc shows */
  .pp-card::after {
    content: "";
    position: absolute;
    inset: 1.5px;
    background: #0c1b32;
    border-radius: 9px;
    z-index: 1;
  }
  /* Stagger starting position per card */
  .pp-card:nth-child(1)::before {
    animation-delay: 0s;
  }
  .pp-card:nth-child(2)::before {
    animation-delay: -1s;
  }
  .pp-card:nth-child(3)::before {
    animation-delay: -2s;
  }
  .pp-card:nth-child(4)::before {
    animation-delay: -3s;
  }

  .pp-card:hover::before {
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 300deg,
      rgba(108, 76, 241, 0.7) 330deg,
      #c4b5fd 348deg,
      rgba(139, 111, 245, 1) 356deg,
      transparent 360deg
    );
    animation-duration: 2.5s;
  }
  .pp-icon {
    position: relative;
    z-index: 2;
    color: var(--color-purple-light);
    margin-bottom: 0.65rem;
    line-height: 0;
  }
  .pp-title {
    position: relative;
    z-index: 2;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .pp-desc {
    position: relative;
    z-index: 2;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  @keyframes worm-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-sub {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-visual {
      order: -1;
    }
    .hero-mockup {
      max-width: 380px;
    }
  }
  @media (max-width: 480px) {
    .hero {
      padding: 100px 0 60px;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
