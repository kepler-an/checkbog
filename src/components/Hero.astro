        <rect x="10" y="40" width="440" height="14" fill="#0f1e38"/>
        <!-- Traffic lights -->
        <circle cx="38" cy="32" r="7" fill="#FF5F57"/>
        <circle cx="60" cy="32" r="7" fill="#FEBC2E"/>
        <circle cx="82" cy="32" r="7" fill="#28C840"/>
        <!-- URL bar -->
        <rect x="110" y="22" width="220" height="20" rx="6" fill="#1a2d4a"/>
        <text x="220" y="36" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-size="10" font-family="monospace">checkbog.com</text>

        <!-- Sidebar -->
        <rect x="22" y="68" width="90" height="250" rx="8" fill="#0f1e38"/>
        <rect x="34" y="84" width="66" height="8" rx="4" fill="rgba(108,76,241,0.6)"/>
        <rect x="34" y="100" width="50" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
        <rect x="34" y="114" width="58" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
        <rect x="34" y="128" width="44" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
        <rect x="34" y="142" width="52" height="6" rx="3" fill="rgba(108,76,241,0.3)"/>

        <!-- Main content area -->
        <!-- Metric cards -->
        <rect x="126" y="68" width="100" height="72" rx="8" fill="#0f1e38"/>
        <text x="176" y="90" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="9">Visitantes</text>
        <text x="176" y="114" text-anchor="middle" fill="#FFC107" font-size="20" font-weight="bold">1,248</text>
        <text x="176" y="130" text-anchor="middle" fill="#28C840" font-size="9">↑ 18%</text>

        <rect x="236" y="68" width="100" height="72" rx="8" fill="#0f1e38"/>
        <text x="286" y="90" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="9">Conversiones</text>
        <text x="286" y="114" text-anchor="middle" fill="#8B6FF5" font-size="20" font-weight="bold">87</text>
        <text x="286" y="130" text-anchor="middle" fill="#28C840" font-size="9">↑ 34%</text>

        <rect x="346" y="68" width="98" height="72" rx="8" fill="#0f1e38"/>
        <text x="395" y="90" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="9">Velocidad</text>
        <text x="395" y="114" text-anchor="middle" fill="#28C840" font-size="20" font-weight="bold">97</text>
        <text x="395" y="130" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-size="9">Lighthouse</text>

        <!-- Chart area -->
        <rect x="126" y="152" width="318" height="154" rx="8" fill="#0f1e38"/>
        <text x="145" y="172" fill="rgba(255,255,255,0.5)" font-size="9">Tráfico mensual</text>

        <!-- Chart bars -->
        <rect x="150" y="248" width="22" height="40" rx="3" fill="rgba(108,76,241,0.4)"/>
        <rect x="182" y="228" width="22" height="60" rx="3" fill="rgba(108,76,241,0.5)"/>
        <rect x="214" y="218" width="22" height="70" rx="3" fill="rgba(108,76,241,0.55)"/>
        <rect x="246" y="208" width="22" height="80" rx="3" fill="rgba(108,76,241,0.6)"/>
        <rect x="278" y="195" width="22" height="93" rx="3" fill="rgba(108,76,241,0.7)"/>
        <rect x="310" y="180" width="22" height="108" rx="3" fill="rgba(108,76,241,0.8)"/>
        <rect x="342" y="165" width="22" height="123" rx="3" fill="#6C4CF1"/>
        <rect x="374" y="155" width="22" height="133" rx="3" fill="#8B6FF5"/>

        <!-- Upward chart line -->
        <polyline points="161,246 193,226 225,216 257,206 289,193 321,178 353,163 385,153"
          stroke="#FFC107" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <!-- Dot at end -->
        <circle cx="385" cy="153" r="4" fill="#FFC107"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px 0 80px;
  }
  .hero-glow {
    position: absolute;
    top: -160px;
    right: -160px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(108,76,241,0.22) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-light);
    margin-bottom: 1rem;
  }
  .hero-headline {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-visual { display: flex; justify-content: center; }
  .hero-mockup {
    width: 100%;
    max-width: 480px;
    filter: drop-shadow(0 20px 50px rgba(108,76,241,0.3));
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-visual { order: -1; }
    .hero-mockup { max-width: 380px; }
  }
  @media (max-width: 480px) {
    .hero { padding: 100px 0 60px; }
    .hero-actions { flex-direction: column; align-items: center; }
    .btn { width: 100%; justify-content: center; }
  }
</style>
