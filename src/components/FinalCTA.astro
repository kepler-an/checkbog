---
const WA_URL = "https://wa.me/50661359054?text=Hola%2C%20quiero%20mas%20informacion%20sobre%20los%20planes";
---
<section class="finalcta" id="contacto">
  <div class="container finalcta-inner reveal">
    <h2 class="finalcta-title">¿Listo para dejar de perder clientes?</h2>
    <p class="finalcta-body">Revisamos tu web gratis, sin compromiso.</p>
    <div class="btn-hint-wrapper">
      <a href={WA_URL} target="_blank" rel="noopener" class="btn btn-yellow finalcta-btn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escribenos ahora →
      </a>
      <span class="cursor-hint" aria-hidden="true">
        <svg width="20" height="24" viewBox="0 0 20 24" fill="none">
          <path d="M2 1L2 19L6.5 14.5L9.5 21.5L12.5 20.5L9.5 13.5L16 13.5L2 1Z"
                fill="white" stroke="#1a1a2e" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <span class="cursor-ripple"></span>
      </span>
    </div>
    <p class="finalcta-note">Respuesta en menos de 24h · Sin contratos forzosos</p>
  </div>
</section>

<style>
  .finalcta {
    background: linear-gradient(135deg, var(--color-navy) 0%, #1a0a4a 50%, var(--color-navy-light) 100%);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }
  .finalcta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(108,76,241,0.25) 0%, transparent 65%);
    pointer-events: none;
  }
  .finalcta-inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .finalcta-title {
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .finalcta-body {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.72);
    margin-bottom: 2.25rem;
  }
  .finalcta-btn {
    font-size: 1.1rem;
    padding: 1rem 2.25rem;
    box-shadow: 0 6px 24px rgba(255,193,7,0.3);
  }

  /* ── Cursor hint ── */
  @keyframes cursor-move {
    0%   { transform: translateY(-50%) translate(52px, -32px); opacity: 0; }
    10%  { transform: translateY(-50%) translate(52px, -32px); opacity: 1; }
    42%  { transform: translateY(-50%) translate(0, 0);        opacity: 1; }
    52%  { transform: translateY(-50%) translate(0, 0) scale(0.78); opacity: 1; }
    63%  { transform: translateY(-50%) translate(0, 0) scale(1);    opacity: 1; }
    78%  { transform: translateY(-50%) translate(52px, -32px); opacity: 1; }
    90%  { transform: translateY(-50%) translate(52px, -32px); opacity: 0; }
    100% { transform: translateY(-50%) translate(52px, -32px); opacity: 0; }
  }
  @keyframes cursor-ripple {
    0%, 49% { width: 0; height: 0; opacity: 0.65; }
    68%     { width: 38px; height: 38px; opacity: 0; }
    100%    { width: 0;    height: 0;    opacity: 0; }
  }

  .btn-hint-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 1.25rem;
  }
  .cursor-hint {
    position: absolute;
    top: 50%;
    right: 28px;
    pointer-events: none;
    animation: cursor-move 4s cubic-bezier(0.4, 0, 0.2, 1) 1.4s infinite both;
  }
  .cursor-ripple {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
    transform: translate(-50%, -50%);
    animation: cursor-ripple 4s 1.4s infinite both;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-hint { display: none; }
  }

  .finalcta-note {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.02em;
  }
</style>
